{"componentChunkName":"component---src-templates-the-notebook-tsx","path":"/the-notebook/database/postgres","result":{"data":{"content":{"frontmatter":{"title":"PostgreSQL","path":"the-notebook/database/postgres","type":"docs"},"html":"<h3>PostgreSQL</h3>\n<h4>Backup</h4>\n<h5>pg_dump <db-name> <backup-file></h5>\n<ul>\n<li>pg_dump -U username table > file.bak</li>\n</ul>\n<div class=\"gatsby-highlight\" data-language=\"text\"><pre class=\"language-text\"><code class=\"language-text\">pg_dump -U postgres project > backup_db.bak</code></pre></div>\n<h4>Restore</h4>\n<ul>\n<li>psql -U <username> <dbname> &#x3C; <filename>.sql</li>\n</ul>\n<div class=\"gatsby-highlight\" data-language=\"text\"><pre class=\"language-text\"><code class=\"language-text\">psql -U postgres project &lt; backup.bak</code></pre></div>\n<ul>\n<li>pg_restore -U <username> -d <dbname> -1 <filename>.dump</li>\n</ul>\n<div class=\"gatsby-highlight\" data-language=\"text\"><pre class=\"language-text\"><code class=\"language-text\">pg_restore -U postgres -d project -1 backup.dump</code></pre></div>\n<div class=\"gatsby-highlight\" data-language=\"text\"><pre class=\"language-text\"><code class=\"language-text\">cat dump.sql | docker exec</code></pre></div>"}},"pageContext":{"pathSlug":"the-notebook/database/postgres"}},"staticQueryHashes":["1506740102","3649515864"],"slicesMap":{}}